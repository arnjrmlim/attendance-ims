RewriteEngine On
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [L]

# ── SVG MIME type ────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType image/svg+xml .svg .svgz
</IfModule>

# ── Prevent browsers from caching assets indefinitely ───────────────────────
# Assets served with ?v= query strings will be treated as new files;
# this ensures the browser re-validates when the version changes.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/svg+xml "access plus 1 year"
</IfModule>

# Force re-validation for SVG specifically so the new logo is picked up
<FilesMatch "\.svg$">
    <IfModule mod_headers.c>
        Header set Cache-Control "public, max-age=31536000, immutable"
    </IfModule>
</FilesMatch>
