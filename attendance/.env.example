# ──────────────────────────────────────────────────────────────
# Attendance Management System — Environment Configuration
# Copy this file to ".env" (same folder) and adjust the values
# for your XAMPP / Windows installation.
#
# NOTE: The application reads these via getenv(). On XAMPP/Apache,
# the simplest way to load them is to set them as Windows System
# Environment Variables, OR use vlucas/phpdotenv (already listed
# in composer.json) by adding the following two lines near the
# top of public/index.php and cron/bootstrap.php, immediately
# after the vendor/autoload.php require:
#
#   $dotenv = Dotenv\Dotenv::createImmutable(dirname(__DIR__));
#   $dotenv->safeLoad();
#
# If no .env is present, the application falls back to the
# defaults already hard-coded in config/database.php and
# config/app.php, so XAMPP's default root/no-password MySQL
# setup will work out of the box without any .env file.
# ──────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=attendance_db
DB_USERNAME=root
DB_PASSWORD=

# ── Application ─────────────────────────────────────────────
APP_NAME="Attendance Management System"
APP_TIMEZONE=Asia/Manila
APP_BASE_URL=/attendance-ims/attendance/public

# ── Email / SMTP (also configurable at Admin > Email Settings) ─
# These are only used to seed the `settings` table on first
# install (see database/seed.sql). Once the app is running,
# manage SMTP credentials from the Email Settings screen —
# they are stored (and take precedence) in the database.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME="Attendance System"
MAIL_FROM_ADDRESS=
MAIL_TO_MAIN_BRANCH=
MAIL_RETRY_INTERVAL_MINUTES=30
MAIL_MAX_RETRIES=5

# ── Backups ──────────────────────────────────────────────────
# Absolute Windows path OUTSIDE the public web root, e.g.:
# C:\xampp\attendance-backups
BACKUP_STORAGE_PATH=C:\xampp\attendance-backups
BACKUP_RETENTION_DAYS=90

# ── Security ─────────────────────────────────────────────────
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
